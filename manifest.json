{
  "manifest_version": 3,
  "name": "คีย์ลัด (789BET Shortcuts)",
  "description": "ส่วนขยายคีย์ลัดบนเว็บไซต์",
  "version": "1.2.2",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "คีย์ลัดเว็บไซต์",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "webNavigation"
  ],

  "host_permissions": [
    "https://api-key-lat.thaideal.co/*"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "type": "module",
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_start"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "snippets.js",
        "handlers.js",
        "confetti.js",
        "dom-utils.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
